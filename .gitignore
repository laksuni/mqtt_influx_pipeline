# Secrets – ignore everything inside secrets/ except readme.md
secrets/*
!secrets/readme.md

# .env file (local environment variables)
.env

# Data files (CSV exports)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store

# Development archive (obsolete scripts, experiments)
dev_archive/

# Vendor directories (if any)
vend/

